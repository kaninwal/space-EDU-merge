<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="StyleCustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">@dimen/_16sdp</item>
        <item name="android:layout_marginEnd">@dimen/_16sdp</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/_8sdp</item>
        <item name="boxCornerRadiusBottomStart">@dimen/_8sdp</item>
        <item name="boxCornerRadiusTopEnd">@dimen/_8sdp</item>
        <item name="boxCornerRadiusTopStart">@dimen/_8sdp</item>
        <item name="endIconTint">@color/color_gray_dark</item>
        <item name="boxStrokeColor">@color/color_accent</item>
        <item name="boxStrokeErrorColor">@color/color_red</item>
        <item name="errorIconTint">@color/color_red</item>
        <item name="errorTextColor">@color/color_red</item>
    </style>

    <style name="StyleCustomTextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">@dimen/_8sdp</item>
        <item name="android:imeOptions">actionNext</item>
        <item name="android:paddingBottom">@dimen/_8sdp</item>
        <item name="android:drawablePadding">@dimen/_8sdp</item>
        <item name="android:drawableTint">@color/color_gray_dark</item>
        <item name="android:fontFamily">@font/font_poppins</item>
        <item name="android:textColor">@color/color_black</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="StyleCircleIcon">
        <item name="android:layout_width">@dimen/_32sdp</item>
        <item name="android:layout_height">@dimen/_32sdp</item>
        <item name="android:layout_marginStart">@dimen/_16sdp</item>
        <item name="android:layout_marginEnd">@dimen/_16sdp</item>
        <item name="android:layout_marginTop">@dimen/_8sdp</item>
        <item name="android:layout_marginBottom">@dimen/_8sdp</item>
        <item name="android:background">@drawable/selector_round_ripple</item>
        <item name="android:elevation">@dimen/_1sdp</item>
        <item name="android:padding">@dimen/_4sdp</item>
    </style>

    <style name="StyleCustomButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:background">@drawable/gradient_accent_dark_round</item>
        <item name="android:fontFamily">@font/font_poppins</item>
        <item name="android:paddingStart">@dimen/_40sdp</item>
        <item name="android:paddingEnd">@dimen/_40sdp</item>
        <item name="android:paddingTop">@dimen/_8sdp</item>
        <item name="android:paddingBottom">@dimen/_8sdp</item>
        <item name="android:textColor">@color/color_white</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="StyleSocialMediaIcon">
        <item name="android:layout_width">@dimen/_32sdp</item>
        <item name="android:layout_height">@dimen/_32sdp</item>
        <item name="android:layout_margin">@dimen/_12sdp</item>
        <item name="android:background">@drawable/bg_circle_solid</item>
        <item name="android:elevation">@dimen/_2sdp</item>
    </style>

    <style name="StyleDrawerMenuItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">@dimen/_1sdp</item>
        <item name="android:layout_marginEnd">@dimen/_1sdp</item>
        <item name="android:paddingStart">@dimen/_16sdp</item>
        <item name="android:paddingEnd">@dimen/_16sdp</item>
        <item name="android:paddingTop">@dimen/_12sdp</item>
        <item name="android:paddingBottom">@dimen/_12sdp</item>
        <item name="android:background">@drawable/selector_ripple</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fontFamily">@font/font_poppins_medium</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">@color/color_black</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="StyleCardSTextHeading">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/_8sdp</item>
        <item name="android:fontFamily">@font/font_poppins_medium</item>
        <item name="android:textColor">@color/color_black</item>
        <item name="android:textSize">@dimen/_10ssp</item>
    </style>

    <style name="StyleCardSTextSubHeading">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/font_poppins</item>
        <item name="android:textColor">@color/color_gray_dark</item>
        <item name="android:textSize">@dimen/_9ssp</item>
    </style>

    <style name="StyleSectionTextHeading">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/font_poppins_semibold</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/color_black</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="StyleSectionUnderline">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/_2sdp</item>
        <item name="android:paddingStart">@dimen/_4sdp</item>
        <item name="android:paddingEnd">@dimen/_4sdp</item>
        <item name="android:layout_marginTop">@dimen/_4sdp</item>
        <item name="android:background">@drawable/gradient_secondary_start</item>
    </style>

    <style name="StyleImageIcon">
        <item name="android:layout_width">@dimen/_32sdp</item>
        <item name="android:layout_height">@dimen/_32sdp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:adjustViewBounds">true</item>
        <item name="android:layout_marginEnd">@dimen/_8sdp</item>
        <item name="android:background">@drawable/bg_full_round_solid_stroke</item>
        <item name="android:backgroundTint">@color/color_ternary</item>
        <item name="android:padding">@dimen/_8sdp</item>
    </style>

    <style name="StyleEditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:singleLine">true</item>
        <item name="android:layout_margin">@dimen/_6sdp</item>
        <item name="android:background">@drawable/bg_low_round_solid_stroke</item>
        <item name="android:drawablePadding">@dimen/_8sdp</item>
        <item name="android:drawableTint">@color/color_gray_dark</item>
        <item name="android:padding">@dimen/_10sdp</item>
        <item name="android:textColor">@color/color_black</item>
        <item name="android:textColorHint">@color/color_gray</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="StyleDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">@dimen/_54sdp</item>
        <item name="android:layout_marginEnd">@dimen/_16sdp</item>
        <item name="android:background">@color/color_gray_light</item>
    </style>

    <style name="StyleCheckIcon">
        <item name="android:layout_width">@dimen/_24sdp</item>
        <item name="android:layout_height">@dimen/_24sdp</item>
        <item name="android:layout_marginStart">@dimen/_2sdp</item>
        <item name="android:layout_marginEnd">@dimen/_14sdp</item>
        <item name="android:background">@drawable/bg_full_round_solid_stroke</item>
        <item name="android:backgroundTint">@color/color_ternary</item>
        <item name="android:padding">4dp</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:src">@drawable/ic_check</item>
    </style>

    <style name="StyleDot">
        <item name="android:layout_width">@dimen/_4sdp</item>
        <item name="android:layout_height">@dimen/_4sdp</item>
        <item name="android:layout_marginStart">@dimen/_8sdp</item>
        <item name="android:layout_marginEnd">@dimen/_8sdp</item>
        <item name="android:background">@drawable/bg_circle_solid</item>
        <item name="android:backgroundTint">@color/color_gray_dark</item>
    </style>
</resources>