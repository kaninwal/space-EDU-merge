<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- White background -->
    <solid android:color="#FFFFFF"/>

      <!-- You can use #FFCC33 for deeper yellow -->

    <!-- Fully rounded corners to get pill shape -->
    <corners android:radius="50dp"/>

    <!-- Add a little padding inside if needed -->
    <padding
        android:left="5dp"
        android:right="5dp"
        android:top="1dp"
        android:bottom="1dp"/>
</shape>
