<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="@dimen/_12sdp"
    android:background="@drawable/bg_full_round_solid_stroke"
    android:elevation="@dimen/_2sdp"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/_16sdp"
    android:paddingTop="@dimen/_12sdp"
    android:paddingBottom="@dimen/_32sdp">

    <TextView
        android:id="@+id/tv_title"
        style="@style/StyleSectionTextHeading"
        android:fontFamily="@font/font_poppins_medium"
        android:text="@string/app_name"
        android:textColor="@color/color_accent" />

    <TextView
        android:id="@+id/tv_description"
        style="@style/StyleSectionTextHeading"
        android:layout_marginTop="@dimen/_8sdp"
        android:fontFamily="@font/font_poppins"
        android:gravity="start"
        android:text="@string/app_name"
        android:textColor="@color/color_gray_dark" />

    <View
        style="@style/StyleDivider"
        android:layout_marginVertical="@dimen/_8sdp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp" />

    <TextView
        style="@style/StyleSectionTextHeading"
        android:fontFamily="@font/font_poppins_medium"
        android:text="@string/text_roles_n_responsibilities"
        android:textColor="@color/color_gray_dark" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_4sdp"
        android:gravity="center_vertical">

        <View style="@style/StyleDot" />

        <TextView
            android:id="@+id/tv_rnr_1"
            style="@style/StyleSectionTextHeading"
            android:fontFamily="@font/font_poppins"
            android:text="@string/app_name"
            android:textColor="@color/color_gray_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <View style="@style/StyleDot" />

        <TextView
            android:id="@+id/tv_rnr_2"
            style="@style/StyleSectionTextHeading"
            android:fontFamily="@font/font_poppins"
            android:text="@string/app_name"
            android:textColor="@color/color_gray_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <View style="@style/StyleDot" />

        <TextView
            android:id="@+id/tv_rnr_3"
            style="@style/StyleSectionTextHeading"
            android:fontFamily="@font/font_poppins"
            android:text="@string/app_name"
            android:textColor="@color/color_gray_dark" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_rnr_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <View style="@style/StyleDot" />

        <TextView
            android:id="@+id/tv_rnr_4"
            style="@style/StyleSectionTextHeading"
            android:fontFamily="@font/font_poppins"
            android:text="@string/app_name"
            android:textColor="@color/color_gray_dark" />
    </LinearLayout>

    <View
        style="@style/StyleDivider"
        android:layout_marginVertical="@dimen/_8sdp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp" />

    <TextView
        style="@style/StyleSectionTextHeading"
        android:fontFamily="@font/font_poppins_medium"
        android:text="@string/text_time_commitment"
        android:textColor="@color/color_gray_dark" />

    <TextView
        android:id="@+id/tv_time"
        style="@style/StyleSectionTextHeading"
        android:layout_marginTop="@dimen/_4sdp"
        android:fontFamily="@font/font_poppins"
        android:text="@string/app_name"
        android:textColor="@color/color_gray_dark" />

    <View
        style="@style/StyleDivider"
        android:layout_marginVertical="@dimen/_8sdp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp" />

    <TextView
        style="@style/StyleSectionTextHeading"
        android:fontFamily="@font/font_poppins_medium"
        android:text="@string/text_perks"
        android:textColor="@color/color_gray_dark" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_4sdp"
        android:gravity="center_vertical">

        <View style="@style/StyleDot" />

        <TextView
            android:id="@+id/tv_perks_1"
            style="@style/StyleSectionTextHeading"
            android:fontFamily="@font/font_poppins"
            android:text="@string/app_name"
            android:textColor="@color/color_gray_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <View style="@style/StyleDot" />

        <TextView
            android:id="@+id/tv_perks_2"
            style="@style/StyleSectionTextHeading"
            android:fontFamily="@font/font_poppins"
            android:text="@string/app_name"
            android:textColor="@color/color_gray_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <View style="@style/StyleDot" />

        <TextView
            android:id="@+id/tv_perks_3"
            style="@style/StyleSectionTextHeading"
            android:fontFamily="@font/font_poppins"
            android:text="@string/app_name"
            android:textColor="@color/color_gray_dark" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <View style="@style/StyleDot" />

        <TextView
            android:id="@+id/tv_perks_4"
            style="@style/StyleSectionTextHeading"
            android:fontFamily="@font/font_poppins"
            android:text="@string/app_name"
            android:textColor="@color/color_gray_dark" />
    </LinearLayout>

</LinearLayout>