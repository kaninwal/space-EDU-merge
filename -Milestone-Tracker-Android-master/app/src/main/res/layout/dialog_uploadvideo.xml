<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/_16sdp"
    android:background="@drawable/bg_full_round_solid_stroke">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Milestone Video"
            android:textSize="@dimen/_20ssp"
            android:textColor="@color/color_black"
            android:fontFamily="@font/font_poppins_bold" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="@dimen/_5sdp"
            />
    </RelativeLayout>

    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload the video of your child's milestone task completion which will be verified by admin"
        android:textSize="@dimen/_12ssp"
        android:textColor="@color/color_gray_dark"
        android:layout_marginTop="@dimen/_6sdp"
        android:fontFamily="@font/font_poppins"/>

    <TextView
        android:id="@+id/tv_upload_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload"
        android:textSize="@dimen/_14ssp"
        android:textColor="@color/color_black"
        android:fontFamily="@font/font_poppins_semibold"
        android:layout_marginTop="@dimen/_20sdp" />


    <LinearLayout
        android:id="@+id/ll_upload_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/_8sdp"
        android:background="@drawable/bg_low_round_solid_stroke"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_upload_link"
            android:layout_width="0dp"
            android:layout_height="@dimen/_40sdp"
            android:layout_weight="1"
            android:hint="Paste link or upload the video"
            android:textColor="@color/color_black"
            android:textSize="@dimen/_12ssp"
            android:paddingStart="@dimen/_13sdp"
            android:paddingEnd="@dimen/_13sdp"
            android:background="@android:color/transparent"
            android:inputType="textUri"
            android:maxLines="1"
            tools:ignore="RtlSymmetry" />

        <ImageButton
            android:id="@+id/btn_upload_file"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/ic_upload"
            android:background="@drawable/gradient_primary_up"
            android:padding="12dp"
            android:minWidth="50dp"
            android:contentDescription="Upload file" />

    </LinearLayout>

<!--    <TextView-->
<!--        android:id="@+id/tv_description_title"-->
<!--        android:layout_width="wrap_content"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:text="Description"-->
<!--        android:textSize="@dimen/_14ssp"-->
<!--        android:textColor="@color/color_black"-->
<!--        android:fontFamily="@font/font_poppins_medium"-->
<!--        android:layout_marginTop="24dp" />-->

<!--    <EditText-->
<!--        android:id="@+id/et_description"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="@dimen/_80sdp"-->
<!--        android:layout_marginTop="@dimen/_8sdp"-->
<!--        android:textColor="@color/color_black"-->
<!--        android:hint="Explain the video's description..."-->
<!--        android:gravity="top"-->
<!--        android:padding="@dimen/_14sdp"-->
<!--        android:background="@drawable/bg_low_round_solid_stroke"-->
<!--        android:inputType="textMultiLine" />-->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_16sdp"
        android:layout_gravity="center"
        android:layout_marginVertical="@dimen/_16sdp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_cancel"
            style="@style/StyleCustomButton"
            android:layout_marginEnd="@dimen/_6sdp"
            android:background="@drawable/bg_full_round_solid_stroke"
            android:textColor="@color/color_black"
            android:paddingStart="@dimen/_30sdp"
            android:paddingEnd="@dimen/_30sdp"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Cancel" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_submit"
            style="@style/StyleCustomButton"
            android:paddingStart="@dimen/_28sdp"
            android:paddingEnd="@dimen/_28sdp"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="Submit" />

    </LinearLayout>
</LinearLayout>