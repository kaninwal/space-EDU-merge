<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:fillViewport="true">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/linearLayout5"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:srcCompat="@drawable/logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Spaces Web Portal"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_menu_library"
                app:tint="@color/black"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- Scroll View for Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/linearLayout5"
        android:layout_above="@+id/bottom_footer"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:paddingVertical="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#EEEEEE"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="Consultant Register"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="20dp"/>

                    <!-- Office Address -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Office Address"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                    <EditText
                        android:id="@+id/Consultant_Address"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rounded_edittext"
                        android:backgroundTint="#FFFFFF"
                        android:hint="Enter Office Address"
                        android:inputType="textPostalAddress"
                        android:paddingHorizontal="12dp"
                        android:textSize="12sp"
                        android:textColor="@color/black"/>

                    <!-- Start Time -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start Time"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/TimeStart"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rounded_edittext"
                        android:backgroundTint="#FFFFFF"
                        android:hint="Start Time"
                        android:focusable="false"
                        android:paddingHorizontal="12dp"
                        android:textSize="12sp"
                        android:textColor="@color/black"/>

                    <!-- End Time -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="End Time"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/TimeEnd"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rounded_edittext"
                        android:backgroundTint="#FFFFFF"
                        android:hint="End Time"
                        android:focusable="false"
                        android:paddingHorizontal="12dp"
                        android:textSize="12sp"
                        android:textColor="@color/black"/>

                    <!-- Availability -->
                    <TextView
                        android:id="@+id/Announcement"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Days Available"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/Consultant_Day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <ToggleButton android:id="@+id/Mon" style="@style/toggleButton" android:layout_width="35dp" android:layout_height="35dp" android:background="@drawable/toggle_bg" android:textOff="Mon" android:textOn="Mon" android:layout_marginEnd="4dp"/>
                            <ToggleButton android:id="@+id/Tue" style="@style/toggleButton" android:layout_width="35dp" android:layout_height="35dp" android:background="@drawable/toggle_bg" android:textOff="Tue" android:textOn="Tue" android:layout_marginEnd="4dp"/>
                            <ToggleButton android:id="@+id/Wed" style="@style/toggleButton" android:layout_width="35dp" android:layout_height="35dp" android:background="@drawable/toggle_bg" android:textOff="Wed" android:textOn="Wed" android:layout_marginEnd="4dp"/>
                            <ToggleButton android:id="@+id/Thu" style="@style/toggleButton" android:layout_width="35dp" android:layout_height="35dp" android:background="@drawable/toggle_bg" android:textOff="Thu" android:textOn="Thu" android:layout_marginEnd="4dp"/>
                            <ToggleButton android:id="@+id/Fri" style="@style/toggleButton" android:layout_width="35dp" android:layout_height="35dp" android:background="@drawable/toggle_bg" android:textOff="Fri" android:textOn="Fri" android:layout_marginEnd="4dp"/>
                            <ToggleButton android:id="@+id/Sat" style="@style/toggleButton" android:layout_width="35dp" android:layout_height="35dp" android:background="@drawable/toggle_bg" android:textOff="Sat" android:textOn="Sat" android:layout_marginEnd="4dp"/>
                            <ToggleButton android:id="@+id/Sun" style="@style/toggleButton" android:layout_width="35dp" android:layout_height="35dp" android:background="@drawable/toggle_bg" android:textOff="Sun" android:textOn="Sun"/>

                        </LinearLayout>
                    </HorizontalScrollView>


                    <!-- Language -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Language"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>
                    <Spinner
                        android:id="@+id/Consultant_Language"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rounded_edittext"
                        android:backgroundTint="#FFFFFF"/>

                    <!-- Fee -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fee"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/Consultant_Fee"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rounded_edittext"
                        android:backgroundTint="#FFFFFF"
                        android:hint="Consultation Fee"
                        android:inputType="numberSigned"
                        android:paddingHorizontal="12dp"
                        android:textSize="12sp"
                        android:textColor="@color/black"/>

                    <!-- Qualification -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Qualification"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>
                    <EditText
                        android:id="@+id/Consultant_Qualification"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rounded_edittext"
                        android:backgroundTint="#FFFFFF"
                        android:hint="Enter Qualification"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="12dp"
                        android:textSize="12sp"
                        android:textColor="@color/black"/>

                    <!-- Type (Spinner) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Type"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"/>
                    <Spinner
                        android:id="@+id/Type"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/rounded_edittext"
                        android:backgroundTint="#FFFFFF"/>

                    <!-- Next Button -->
                    <Button
                        android:id="@+id/ConsultantRegistration_Button_Signup"
                        android:layout_width="120dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:text="Next Page"
                        android:textStyle="bold"
                        android:backgroundTint="#FFA500"
                        android:background="@drawable/rectangle_8_login_button"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ellipse_i_login"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/footer_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Still delaying treatment for your child's health concerns?"
            android:textColor="#FFA500"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/ellipse_i_login"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_edittext"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            app:layout_constraintTop_toBottomOf="@+id/footer_text"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/CantactUs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact Us"
                android:layout_marginRight="200dp"
                android:textColor="@color/black"
                android:textSize="14sp"/>

            <ImageView
                android:id="@+id/ArrowDown"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/arrowdown"
                app:tint="@color/black"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>